# Agent environment template
# Use this file as reference to create local .env.agent.

# Local site (required)
LOCAL_SITE_URL=http://localhost:8787
LOCAL_SITE_PASSWORD=

# Cloud site (required when using cloud endpoint)
CLOUD_SITE_URL=
CLOUD_SITE_PASSWORD=

# Cloudflare credentials (required for wrangler deploy/tail)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
